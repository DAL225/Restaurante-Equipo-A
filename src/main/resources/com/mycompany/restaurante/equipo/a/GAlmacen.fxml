<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane fx:id="pnlAlmacen" prefHeight="453.0" prefWidth="522.0" style="-fx-border-color: black;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.restaurante.equipo.a.GAlmacenController">
   <children>
      <Label fx:id="lblAlmacen" layoutX="236.0" layoutY="-1.0" text="Almacen">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>
      <AnchorPane fx:id="pnlAgregarProducto" layoutX="151.0" layoutY="29.0" prefHeight="423.0" prefWidth="370.0" style="-fx-border-color: black; -fx-background-color: d3d3d3;">
         <children>
            <TextField fx:id="txtMarca" layoutX="156.0" layoutY="21.0" prefHeight="26.0" prefWidth="186.0">
               <font>
                  <Font size="15.0" />
               </font>
            </TextField>
            <ChoiceBox fx:id="selecTipo" layoutX="155.0" layoutY="91.0" prefHeight="26.0" prefWidth="186.0" style="-fx-background-color: white;" />
            <Label fx:id="lblMarca" layoutX="23.0" layoutY="23.0" text="Marca :">
               <font>
                  <Font size="15.0" />
               </font>
            </Label>
            <Label fx:id="lblTipo" layoutX="23.0" layoutY="93.0" text="Tipo :">
               <font>
                  <Font size="15.0" />
               </font>
            </Label>
            <Label fx:id="lblProveedor" layoutX="22.0" layoutY="238.0" text="Proveedor :">
               <font>
                  <Font size="15.0" />
               </font>
            </Label>
            <Label fx:id="lblStock" layoutX="21.0" layoutY="166.0" text="Stock :">
               <font>
                  <Font size="15.0" />
               </font>
            </Label>
            <Button fx:id="btnAgregar" layoutX="125.0" layoutY="318.0" mnemonicParsing="false" onAction="#agregar" style="-fx-background-color: Red;" text="Agregar" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="12.0" />
               </font>
            </Button>
            <TextField fx:id="txtProveedor" layoutX="152.0" layoutY="233.0" prefHeight="26.0" prefWidth="186.0">
               <font>
                  <Font size="15.0" />
               </font>
            </TextField>
            <Spinner fx:id="spnStock" layoutX="155.0" layoutY="164.0" stylesheets="@spinner.css" />
         </children>
      </AnchorPane>
      <Button fx:id="btnAgregarProducto" layoutX="1.0" layoutY="45.0" mnemonicParsing="false" onAction="#switchAgregarProducto" style="-fx-background-color: #636AE8;" text="Agregar Producto" textFill="WHITE">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Button fx:id="btnModificarProducto" layoutX="1.0" layoutY="89.0" mnemonicParsing="false" onAction="#switchModificarProducto" style="-fx-background-color: #636AE8;" text="Modificar Producto" textFill="WHITE">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Button fx:id="btnVerProductos" layoutX="2.0" layoutY="191.0" mnemonicParsing="false" onAction="#verProductos" style="-fx-background-color: #636AE8;" text="Ver Productos" textFill="WHITE">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Button fx:id="btnReportemensual" layoutX="1.0" layoutY="311.0" mnemonicParsing="false" onAction="#generarReporte" style="-fx-background-color: #636AE8;" text="Reporte mensual" textFill="WHITE">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
      <Button fx:id="btnEliminarProducto" layoutX="1.0" layoutY="137.0" mnemonicParsing="false" onAction="#switchEliminarProducto" style="-fx-background-color: #636AE8;" text="Eliminar Producto" textFill="WHITE">
         <font>
            <Font name="System Bold" size="12.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
